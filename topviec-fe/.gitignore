# Gitignore - Loại trừ file không cần commit (node_modules, dist, .env, logs...)
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.vite
.cache
coverage
*.tsbuildinfo
.eslintcache

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment variables — KHÔNG commit lên Git
.env
.env.development
.env.production
.env.staging
.env.*
!.env.example
!.env.*.example
.envrc
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
*.secret
secrets/

# LLM Skills Guide (Do not sync with Git)
skill-font.md
skill-Progressive_Disclosure.md
skill-dropdown.md
skill-Pagination.md
skill-designer.md

docs/
